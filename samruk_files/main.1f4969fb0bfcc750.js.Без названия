u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u0446\u0435\u043d\u043e\u0432\u043e\u0433\u043e \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0432&nbsp;\u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044b\u0435 \u0434\u0435\u0434\u043b\u0430\u0439\u043d\u044b","P3_4":"\u041d\u0435&nbsp;\u0437\u0430\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u044f \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u044f \u043e&nbsp;\u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0445 \u0437\u0430\u043a\u0443\u043f\u043a\u0430\u0445 \u0432&nbsp;\u0441\u0440\u043e\u043a\u0438","P3_5":"\u041d\u0435\u043d\u0430\u0434\u043b\u0435\u0436\u0430\u0449\u0435\u043c \u0438\u0441\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0438 \u0443\u0441\u043b\u043e\u0432\u0438\u0439 \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u0430","P3_6":"\u0415\u0441\u043b\u0438 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u044f \u043d\u0430\u0440\u0443\u0448\u0430\u0435\u0442 \u043e\u0434\u0438\u043d \u0438\u0437&nbsp;\u0432\u044b\u0448\u0435\u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u043d\u044b\u0445 \u043f\u0443\u043d\u043a\u0442\u043e\u0432 \u043f\u0440\u0438 \u0443\u0447\u0430\u0441\u0442\u0438\u0438 \u0432&nbsp;\u0442\u0435\u043d\u0434\u0435\u0440\u0435, \u0442\u043e&nbsp;\u0431\u0430\u043d\u043a \u043e\u043f\u043b\u0430\u0447\u0438\u0432\u0430\u0435\u0442 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0442\u043e\u0440\u0443 \u0442\u0435\u043d\u0434\u0435\u0440\u0430 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0439\u043d\u0443\u044e \u0441\u0443\u043c\u043c\u0443. \u0414\u0430\u043b\u0435\u0435 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u044f \u0432\u043e\u0437\u043c\u0435\u0449\u0430\u0435\u0442 \u043f\u043b\u0430\u0442\u0435\u0436 \u0431\u0430\u043d\u043a\u0443.","P4_1":"\u041f\u043e\u043a\u0440\u044b\u0442\u044b\u0435 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0438","P4_2":"\u042d\u0442\u043e \u0431\u0430\u043d\u043a\u043e\u0432\u0441\u043a\u0438\u0435 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0438, \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u043d\u044b\u0435 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u043c\u0438 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043c\u0438. \u0414\u043b\u044f \u0432\u044b\u043f\u0443\u0441\u043a\u0430 \u043f\u043e\u043a\u0440\u044b\u0442\u043e\u0439 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0438 \u043a\u043b\u0438\u0435\u043d\u0442 \u0432\u043d\u043e\u0441\u0438\u0442 100% \u0434\u0435\u043d\u0435\u0436\u043d\u043e\u0435 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435, \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u0432\u044b\u043f\u0443\u0441\u043a\u0430 \u0442\u0430\u043a\u043e\u0439 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0438 \u043e\u0431\u044b\u0447\u043d\u043e \u043d\u0438\u0436\u0435 \u0447\u0435\u043c \u0437\u0430&nbsp;\u0432\u044b\u043f\u0443\u0441\u043a \u043d\u0435\u043f\u043e\u043a\u0440\u044b\u0442\u044b\u0445 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0439.","P4_3":"\u041d\u0435\u043f\u043e\u043a\u0440\u044b\u0442\u044b\u0435 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0438","P4_4":"\u042d\u0442\u043e \u0431\u0430\u043d\u043a\u043e\u0432\u0441\u043a\u0438\u0435 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0438, \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u043d\u044b\u0435 \u0438\u043d\u044b\u043c\u0438 \u0437\u0430\u043b\u043e\u0433\u0430\u043c\u0438, \u043a\u0440\u043e\u043c\u0435 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432. \u0412&nbsp;\u0432\u0438\u0434\u0435 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u043c\u043e\u0433\u0443\u0442 \u0431\u044b\u0442\u044c: \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c, \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u043d\u044b\u0435 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u0438&nbsp;\u0438\u043d\u044b\u0435 \u043c\u0430\u