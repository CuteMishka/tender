b\u044c\u0442\u0440 <strong>&laquo;\u041c\u0435\u0441\u0442\u043e \u043f\u043e\u0441\u0442\u0430\u0432\u043a\u0438&raquo;</strong> \u0438&nbsp;\u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u043e\u0434\u0438\u043d \u0438\u043b\u0438 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u043e\u0432 \u0438\u0437&nbsp;\u0432\u044b\u043f\u0430\u0434\u0430\u044e\u0449\u0435\u0433\u043e \u0441\u043f\u0438\u0441\u043a\u0430.","P8":"\u0414\u0430\u043b\u0435\u0435 \u0434\u043b\u044f \u0432\u044b\u0431\u043e\u0440\u0430 <strong>&laquo;\u0412\u0438\u0434\u0430 \u0437\u0430\u043a\u0443\u043f\u043e\u043a&raquo;</strong>, <strong>&laquo;\u041f\u0440\u0435\u0434\u043c\u0435\u0442\u0430 \u0437\u0430\u043a\u0443\u043f\u043e\u043a&raquo;</strong>, <strong>&laquo;\u0421\u0442\u0430\u0442\u0443\u0441\u0430&raquo;</strong>, <strong>&laquo;\u0412\u0438\u0434\u0430 \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u0430&raquo;</strong> \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430&nbsp;\u0432\u044b\u043f\u0430\u0434\u0430\u044e\u0449\u0438\u0439 \u0441\u043f\u0438\u0441\u043e\u043a \u0438&nbsp;\u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u0439 \u0432\u0430\u0440\u0438\u0430\u043d\u0442 \u0434\u043b\u044f \u0432\u0430\u0448\u0435\u0433\u043e \u043f\u043e\u0438\u0441\u043a\u0430.","P9":"<strong>\u0412\u0438\u0434 \u0437\u0430\u043a\u0443\u043f\u043e\u043a</strong>&nbsp;&mdash; \u044d\u0442\u043e \u0441\u043f\u043e\u0441\u043e\u0431\u044b \u0437\u0430\u043a\u0443\u043f\u043e\u043a, \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u0435\u043d\u043d\u044b\u0435 \u043d\u0430&nbsp;\u043f\u043e\u0440\u0442\u0430\u043b\u0435 zakupki.kz \u0432&nbsp;\u0442\u0430\u043a\u0438\u0435, \u043a\u0430\u043a &laquo;\u0422\u0435\u043d\u0434\u0435\u0440\u044b \u0438&nbsp;\u043a\u043e\u043d\u043a\u0443\u0440\u0441\u044b&raquo;, &laquo;\u0417\u0430\u043f\u0440\u043e\u0441 \u0446\u0435\u043d\u043e\u0432\u044b\u0445 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439&raquo; \u0438&nbsp;&laquo;\u0418\u0437&nbsp;\u043e\u0434\u043d\u043e\u0433\u043e \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430&raquo;. \u0415\u0441\u043b\u0438 \u0432\u0430\u043c \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043d\u0430\u0439\u0442\u0438 \u0441\u043f\u043e\u0441\u043e\u0431 \u0437\u0430\u043a\u0443\u043f\u043a\u0438 &laquo;\u041e\u0442\u043a\u0440\u044b\u0442\u044b\u0439 \u0442\u0435\u043d\u0434\u0435\u0440 \u043d\u0430&nbsp;\u043f\u043e\u043d\u0438\u0436\u0435\u043d\u0438\u0435&raquo;, \u0442\u043e&nbsp;\u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0412\u0438\u0434 \u0437\u0430\u043a\u0443\u043f\u043e\u043a&nbsp;&mdash; &laquo;\u0422\u0435\u043d\u0434\u0435\u0440\u044b \u0438&nbsp;\u043a\u043e\u043d\u043a\u0443\u0440\u0441\u044b&raquo;. \u0415\u0441\u043b\u0438 \u0432\u044b&nbsp;\u0432&nbsp;\u043f\u043e\u0438\u0441\u043a\u0435 &laquo;\u0417\u0430\u043f\u0440\u043e\u0441\u0430 \u0446\u0435\u043d\u043e\u0432\u044b\u0445 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u043d\u0430&nbsp;\u043f\u043e\u043d\u0438\u0436\u0435\u043d\u0438\u0435&raquo;, \u0442\u043e&nbsp;\u043f\u043e\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u0433\u0430\u043b\u043e\u0447\u043a\u0443 \u043d\u0430&nbsp;&laquo;\u0417\u0430\u043f\u0440\u043e\u0441 \u0446\u0435\u043d\u043e\u0432\u044b\u0445 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439&raquo;.","P10":"<strong>\u041f\u0440\u0435\u0434\u043c\u0435\u0442 \u0437\u0430\u043a\u0443\u043f\u043e\u043a</strong>&nbsp;&mdash; \u044d\u0442\u043e \u0442\u043e\u0432\u0430\u0440\u044b, \u0440\u0430\u0431\u043e\u0442\u044b \u0438\u043b\u0438 \u0443\u0441\u043b\u0443\u0433\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0437\u0430\u043a\u0443\u043f\u0430\u044e\u0442\u0441\u044f \u0417\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u043e\u043c \u0441&nbsp;\u043f\u043e\u043c\u043e\u0449\u044c\u044e \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044e\u0449\u0435\u0439 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440\u044b \u0437\u0430\u043a\u0443\u043f\u043a\u0438. \u0415\u0441\u043b\u0438 \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u043a\u0430\u043a \u043f\u0440\u0435\u0434\u043c\u0435\u0442 \u0437\u0430\u043a\u0443\u043f\u043e\u043a&nbsp;&mdash; &laquo;\u0422\u043e\u0432\u0430\u0440\u044b&raquo;, \u0442\u043e&nbsp;\u043f\u0440\u0438 \u043f\u043e\u0438\u0441\u043a\u0435 \u043b\u043e\u0442\u044b \u0441&nbsp;\u0443\u0441\u043b\u0443\u0433\u0430\u043c\u0438 \u0438&nbsp;\u0440\u0430\u0431\u043e\u0442\u0430\u043c\u0438 \u0431\u0443\u0434\u0443\u0442 \u0438\u0441\u043a\u043b\u044e\u0447\u0435\u043d\u044b.","P11":"<strong>\u0421\u0442\u0430\u0442\u0443\u0441 \u0437\u0430\u043a\u0443\u043f\u043e\u043a</strong>&nbsp;&mdash; \u044d\u0442\u043e \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u0437\u0430\u043a\u0443\u043f\u043a\u0438 \u043d\u0430&nbsp;\u0442\u0435\u043a\u0443\u0449\u0438\u0439 \u043c\u043e\u043c\u0435\u043d\u0442. \u0418\u043d\u0444\u043e\u0440\u043c\u0438\u0440\u0443\u0435\u0442 \u043e&nbsp;\u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0441\u0442\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u043a\u0430\u043a\u0438\u0445-\u043b\u0438\u0431\u043e \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439. \u041d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0434\u043b\u044f \u043f\u043e\u0438\u0441\u043a\u0430 \u0437\u0430\u043a\u0443\u043f\u043a\u0438 \u043d\u0430&nbsp;\u043a\u043e\u0442\u043e\u0440\u0443\u044e \u043c\u043e\u0436\u043d\u043e \u043f\u043e\u0434\u0430\u0442\u044c \u0437\u0430\u044f\u0432\u043a\u0443 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0441\u0442\u0430\u0442\u0443\u0441 &laquo;\u041e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u043d\u043e&raquo;. \u041f\u043e&nbsp;\u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u044b \u0441\u0442\u0430\u0442\u0443\u0441\u044b &laquo;\u041f\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043e\u0431\u0441\u0443\u0436\u0434\u0435\u043d\u0438\u0435&raquo; \u0438&nbsp;&laquo;\u041e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u043d\u043e&raquo;.","P12":"<strong>\u0412\u0438\u0434 \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u0430</strong>&nbsp;&mdash; \u0434\u0435\u043b\u0435\u043d\u0438\u0435 \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u043e\u0432 \u043f\u043e&nbsp;\u043f\u043b\u043e\u0449\u0430\u0434\u043a\u0430\u043c, \u043d\u0430&nbsp;\u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0440\u0430\u0437\u043c\u0435\u0449\u0430\u044e\u0442\u0441\u044f \u0437\u0430\u043a\u0443\u043f\u043a\u0438. \u0412\u044b\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u0443\u044e\u0449\u0438\u0435 \u0412\u0430\u0441 \u043f\u043b\u043e\u0449\u0430\u0434\u043a\u0438 \u0438\u0437&nbsp;\u0432\u044b\u043f\u0430\u0434\u0430\u044e\u0449\u0435\u0433\u043e \u0441\u043f\u0438\u0441\u043a\u0430.","P13":"\u0414\u043b\u044f \u043f\u043e\u0438\u0441\u043a\u0430 \u0437\u0430\u043a\u0443\u043f\u043e\u043a \u0441&nbsp;\u043f\u0440\u0438\u0437\u043d\u0430\u043a\u043e\u043c <strong>\u041f\u041a\u041e</strong>, <strong>\u041e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0439 \u0438\u043d\u0432\u0430\u043b\u0438\u0434\u043e\u0432</strong> \u0438\u043b\u0438 <strong>\u0422\u043e\u0432\u0430\u0440\u043e\u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u0435\u0439 \u0425\u043e\u043b\u0434\u0438\u043d\u0433\u0430</strong> \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430&nbsp;\u0432\u044b\u043f\u0430\u0434\u0430\u044e\u0449\u0438\u0439 \u0441\u043f\u0438\u0441\u043e\u043a \u0438&nbsp;\u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442 &laquo;\u0414\u0430&raquo;. \u0412\u0430\u0440\u0438\u0430\u043d\u0442 &laquo;\u041d\u0435\u0442&raquo; \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d \u043f\u043e&nbsp;\u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e.","P14":"<strong>\u0417\u0430\u043a\u0443\u043f\u043a\u0438 \u0441&nbsp;\u043f\u0440\u0438\u0437\u043d\u0430\u043a\u043e\u043c \u041f\u041a\u041e</strong> (\u043f\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043a\u0432\u0430\u043b\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0439 \u043e\u0442\u0431\u043e\u0440)&nbsp;&mdash; \u0437\u0430\u043a\u0443\u043f\u043a\u0438, \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u043c\u044b\u0435 \u0441\u0440\u0435\u0434\u0438 \u043f\u043e\u0441\u0442\u0430\u0432\u0449\u0438\u043a\u043e\u0432, \u043f\u0440\u043e\u0448\u0435\u0434\u0448\u0438\u0445 \u043f\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u043a\u0432\u0430\u043b\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0439 \u043e\u0442\u0431\u043e\u0440 \u0438&nbsp;\u043f\u0440\u043e\u0446\u0435\u0441\u0441 \u043e\u0446\u0435\u043d\u043a\u0438 \u043f\u043e\u0442\u0435\u043d\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0441\u0442\u0430\u0432\u0449\u0438\u043a\u043e\u0432 \u043f\u043e&nbsp;\u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u0430\u043c \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u0437\u0430\u043a\u0443\u043f\u043e\u0447\u043d\u043e\u0439 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c\u044e \u0410\u041e&nbsp;&laquo;\u0424\u041d\u0411 &laquo;\u0421\u0430\u043c\u0440\u0443\u043a-\u041a\u0430\u0437\u044b\u043d\u0430&raquo;, \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u0435\u043c\u044b\u0439 \u043f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043e\u043c \u0430\u043d\u043a\u0435\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0438&nbsp;\u0430\u0443\u0434\u0438\u0442\u0430. \u041f\u041a\u041e \u0442\u0430\u043a\u0436\u0435 \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442 \u043d\u0430&nbsp;\u041f\u043e\u0440\u0442\u0430\u043b\u0435 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0445 \u0437\u0430\u043a\u0443\u043f\u043e\u043a.","P15":"<strong>\u0417\u0430\u043a\u0443\u043f\u043a\u0438 \u0441\u0440\u0435\u0434\u0438 \u041e\u041e\u0418</strong>&nbsp;&mdash; \u0437\u0430\u043a\u0443\u043f\u043a\u0438 \u0441\u0440\u0435\u0434\u0438 \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u0439 \u0438\u043d\u0432\u0430\u043b\u0438\u0434\u043e\u0432 \u0438&nbsp;\u0441\u043e\u0437\u0434\u0430\u043d\u043d\u044b\u043c\u0438 \u0438\u043c\u0438 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f\u043c\u0438. \u041f\u0440\u043e\u0432\u043e\u0434\u044f\u0442\u0441\u044f \u0441\u043e\u0433\u043b\u0430\u0441\u043d\u043e \u041f\u0435\u0440\u0435\u0447\u043d\u044e \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u044b\u0445 \u0432\u0438\u0434\u043e\u0432 \u0442\u043e\u0432\u0430\u0440\u043e\u0432, \u0440\u0430\u0431\u043e\u0442, \u0443\u0441\u043b\u0443\u0433, \u0437\u0430\u043a\u0443\u043f\u0430\u0435\u043c\u044b\u0445 \u0443&nbsp;\u041e\u041e\u0418 \u0420\u0435\u0441\u043f\u0443\u0431\u043b\u0438\u043a\u0438 \u041a\u0430\u0437\u0430\u0445\u0441\u0442\u0430\u043d, \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u044f\u0449\u0438\u0445 \u0438\u043b\u0438 \u043f\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u044e\u0449\u0438\u0445 \u0442\u043e\u0432\u0430\u0440\u044b, \u0440\u0430\u0431\u043e\u0442\u044b \u0438&nbsp;\u0443\u0441\u043b\u0443\u0433\u0438.","P16":"<strong>\u0417\u0430\u043a\u0443\u043f\u043a\u0438 \u0441\u0440\u0435\u0434\u0438 \u0422\u041f\u0424</strong>&nbsp;&mdash; \u0437\u0430\u043a\u0443\u043f\u043a\u0438, \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u043c\u044b\u0435 \u0441\u0440\u0435\u0434\u0438 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0439, \u043d\u0430\u0445\u04