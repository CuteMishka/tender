# CORS: * или список через запятую, например https://app.example.com,http://localhost:5173
# CORS_ORIGINS=*

DATABASE_URL=postgresql://rag:rag@localhost:5437/rag
EMBEDDING_MODEL=intfloat/multilingual-e5-small
# для ingest_local внутри контейнера:
# FILES_DIR=/files

# Разбор текста через Gemini (POST /v1/match/analyze):
# Скопируй этот файл в .env и вставь ключ ТОЛЬКО в .env (он в .gitignore).
# GEMINI_API_KEY=AIzaSy...
# CHAT_MODEL=gemini-2.0-flash

# Профиль компании по умолчанию (если в POST не передали profile):
# COMPANY_PROFILE=Мы оказываем ...
# или длинный текст из файла (в Docker по умолчанию смотрит files/company_profile.txt):
# COMPANY_PROFILE_FILE=/files/company_profile.txt

# Bitrix24 CRM
# BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.kz/rest/1/webhook-token
# BITRIX24_WEBHOOK_SECRET=change-me
# BITRIX24_CURRENCY=KZT

# Commercial proposals / DOCX / S3-MinIO
# CP_TEMPLATE_DIR=files/templates
# CP_VAT_RATE=0.12
# CP_MARGIN_RATE=0.25
# STORAGE_BACKEND=local
# LOCAL_STORAGE_DIR=files/generated
# S3_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET=tender-machine
# S3_REGION=us-east-1
# S3_PUBLIC_BASE_URL=http://localhost:9000

# CitizenSec / VirusTotal
# VIRUSTOTAL_API_KEY=...
