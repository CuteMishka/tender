function generate_pd(announce_id)
{
    $('#errorsPD').hide();
    $('#btnGeneratePD').hide();
    $('#proccessPD').show();
    $.ajax({
        type: "POST",
        url: site_url() + 'ajax_generate_pd/' + announce_id,
        dataType: 'json',
        data: {generate:'Y'},
        success: function (data) {
            if (data.status == 1) {
                location.reload(true);
            }
            else
            {
                $('#errors').html(data.message);
                $('#errors').show();
            }
        },
        error: function () {
            $('#errors').html('Ошибка выполнения запроса, попробуйте позже');
            $('#errors').show();
        }
    });
    return false;
}