DATABASE_URL=postgresql+psycopg://tender:tender@localhost:5433/tender
RAG_API_BASE=http://localhost:8083
POLL_INTERVAL_SECONDS=1800
MAX_WORKERS=4
HEADLESS=true
DOWNLOAD_DIR=./downloads
STRICT_KEYWORD_FILTER=false
COLLECT_ALL_ACTIVE_LOTS=true
SMART_MATCH_ENABLED=true
SMART_MATCH_USE_MORPHOLOGY=true
SEMANTIC_MATCH_ENABLED=false
SEMANTIC_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SEMANTIC_MATCH_THRESHOLD=0.7
MIN_KEYWORD_SCORE=0.55
AI_LOT_FILTER_ENABLED=false
AI_LOT_FILTER_MIN_SCORE=60
AI_COMPANY_PROFILE=
DICTIONARIES_API_URL=http://localhost:8082/api/v1/dictionaries?kind=keywords
STOP_AT_FIRST_SEEN_LOT=false
PROCESS_EXISTING_LOTS=true
MAX_LOTS_PER_CYCLE=0

PLATFORMS=goszakup
DEFAULT_KEYWORDS=простыня,одеяло,подушка
OUR_BINS=123456789012

GOSZAKUP_BASE_URL=https://goszakup.gov.kz
GOSZAKUP_SEARCH_URL=https://goszakup.gov.kz/ru/search/lots
GOSZAKUP_LOTS_COUNT_RECORD=50
GOSZAKUP_LOTS_MAX_PAGES=0
GOSZAKUP_OWS_BASE_URL=https://ows.goszakup.gov.kz
GOSZAKUP_OWS_GRAPHQL_URL=https://ows.goszakup.gov.kz/v3/graphql
GOSZAKUP_OWS_TOKEN=
ZAKUP_PUBLIC_BASE_URL=https://zakup.gov.kz
ZAKUP_LOTS_URL=https://zakup.gov.kz/home/lots
ZAKUP_LOTS_LIMIT=100
ZAKUP_LOTS_MAX_PAGES=0
ZAKUP_LOTS_SYSTEM_IDS=
ZAKUP_OWS_LIMIT_PER_PAGE=200
ZAKUP_OWS_MAX_PAGES_PER_KEYWORD=0
SAMRUK_SEARCH_URL=https://zakupki.kz/result

RAG_EXTRACT_SPEC_POINTS=true
RAG_INCLUDE_EXTRACTED_TEXT=false
REQUEST_TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2
