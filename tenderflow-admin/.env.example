# Копируй в `.env` и меняй при необходимости.
# Vite отдаёт в клиент только переменные с префиксом VITE_.

# Go-бэкенд (tenderai). Локально: http://localhost:8082
VITE_BACK_API=http://localhost:8082

# Python RAG-сервис (tender-rag). Локально: http://localhost:8083
VITE_RAG_API=http://localhost:8083

# Прокси для скачивания документов (тот же Go-бэкенд)
# VITE_FETCH_DOCUMENT_PROXY_URL=http://localhost:8082
